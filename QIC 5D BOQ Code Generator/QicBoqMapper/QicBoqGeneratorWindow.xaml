<Window x:Class="QicBoqMapper.QicBoqGeneratorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="QIC Tools – 5D BOQ Manager"
        Height="550"
        Width="500"
        MinHeight="500"
        MinWidth="440"
        ResizeMode="CanResize"
        SizeToContent="Manual"
        WindowStartupLocation="CenterScreen"
        Topmost="False"
        Background="#0F172A"
        FontFamily="Segoe UI, Inter, Roboto"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True">
    
    <Window.Resources>
        <!-- Modern Custom Button Style -->
        <Style x:Key="PremiumButton" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.75"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#334155"/>
                                <Setter Property="Foreground" Value="#64748B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
 
        <!-- Secondary Button Style -->
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PremiumButton}">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#334155"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0F172A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#0F172A"/>
                                <Setter Property="Foreground" Value="#475569"/>
                                <Setter Property="BorderBrush" Value="#1E293B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
 
        <!-- Radio Button Modern Style -->
        <Style x:Key="ModernRadioButton" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>
 
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="Auto"/> <!-- Scope Selection -->
            <RowDefinition Height="Auto"/> <!-- Filters -->
            <RowDefinition Height="*"/>    <!-- Primary Actions -->
            <RowDefinition Height="Auto"/> <!-- Progress & Status -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="QIC 5D BOQ MANAGER" Foreground="#3B82F6" FontSize="18" FontWeight="Bold"/>
                <TextBlock Text="Model Metadata Linker" Foreground="White" FontSize="20" FontWeight="Bold" Margin="0,2,0,0"/>
            </StackPanel>
        </Grid>

        <!-- Scope Selection Card -->
        <Border Grid.Row="1" Background="#1E293B" CornerRadius="8" Padding="12" Margin="0,0,0,12" BorderBrush="#334155" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Selection Scope" FontWeight="SemiBold" FontSize="13" Foreground="White" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <RadioButton Content="Current Selection" 
                                     IsChecked="{Binding IsCurrentSelectionSelected}" 
                                     Style="{StaticResource ModernRadioButton}"/>
                        <RadioButton Content="Active View" 
                                     IsChecked="{Binding IsActiveViewSelected}" 
                                     Style="{StaticResource ModernRadioButton}"/>
                        <RadioButton Content="Full Model" 
                                     IsChecked="{Binding IsWholeModelSelected}" 
                                     Style="{StaticResource ModernRadioButton}"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                    <TextBlock Text="Separator" FontSize="12" Foreground="White" Margin="2,0,0,0"/>
                    <ComboBox ItemsSource="{Binding SeparatorStyles}"
                              SelectedItem="{Binding SeparatorStyle}"
                              Width="60" Height="22"
                              VerticalContentAlignment="Center"
                              Background="#0F172A" Foreground="Black" BorderBrush="#334155"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Filters (Optional) Card -->
        <Border Grid.Row="2" Background="#1E293B" CornerRadius="8" Padding="12" Margin="0,0,0,12" BorderBrush="#334155" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Filters (Optional)" FontWeight="SemiBold" FontSize="13" Foreground="White" Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Margin="0,0,4,0">
                        <TextBlock Text="Category" FontSize="10" Foreground="#94A3B8" Margin="0,0,0,3"/>
                        <ToggleButton x:Name="CategoryDropdownButton" Height="28"
                                      Background="#0F172A" BorderBrush="#334155" BorderThickness="1"
                                      HorizontalContentAlignment="Left" VerticalContentAlignment="Center" Padding="5,0">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ContentPresenter Grid.Column="0" VerticalAlignment="Center" Margin="5,0"/>
                                            <Path Grid.Column="1" Data="M 0 0 L 3.5 4 L 7 0 Z" Fill="#94A3B8" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </ControlTemplate>
                            </ToggleButton.Template>
                            <TextBlock Text="{Binding SelectedCategoriesSummary}" Foreground="White" FontSize="10" TextTrimming="CharacterEllipsis"/>
                        </ToggleButton>
                        <Popup IsOpen="{Binding IsChecked, ElementName=CategoryDropdownButton, Mode=TwoWay}"
                               PlacementTarget="{Binding ElementName=CategoryDropdownButton}"
                               Placement="Bottom"
                               StaysOpen="False"
                               PopupAnimation="Fade"
                               Width="220">
                            <Border Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="4" Padding="8">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="180"/>
                                    </Grid.RowDefinitions>
                                    <!-- All / None select buttons -->
                                    <Grid Grid.Row="0" Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Content="All" Click="SelectAllCategories_Click" Style="{StaticResource SecondaryButton}" Height="20" Margin="0,0,2,0" FontSize="10"/>
                                        <Button Content="None" Click="SelectNoCategories_Click" Style="{StaticResource SecondaryButton}" Height="20" Margin="2,0,0,0" FontSize="10"/>
                                    </Grid>
                                    <!-- Checkbox List -->
                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding CategoryItems}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding IsSelected}" Content="{Binding Name}" Margin="2,3" Foreground="#E2E8F0" FontSize="11"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </Popup>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="4,0,4,0">
                        <TextBlock Text="Family" FontSize="10" Foreground="#94A3B8" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding FamilyFilterText, UpdateSourceTrigger=PropertyChanged}" 
                                 Height="28" VerticalContentAlignment="Center" Padding="5,0"
                                 Background="#0F172A" BorderBrush="#334155" BorderThickness="1" Foreground="White" CaretBrush="White"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="4,0,0,0">
                        <TextBlock Text="Type" FontSize="10" Foreground="#94A3B8" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding TypeFilterText, UpdateSourceTrigger=PropertyChanged}" 
                                 Height="28" VerticalContentAlignment="Center" Padding="5,0"
                                 Background="#0F172A" BorderBrush="#334155" BorderThickness="1" Foreground="White" CaretBrush="White"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Primary Action Buttons Card -->
        <Border Grid.Row="3" Background="#1E293B" CornerRadius="8" Padding="12" Margin="0,0,0,12" BorderBrush="#334155" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Command="{Binding ExportElementsCommand}" 
                        Style="{StaticResource SecondaryButton}" 
                        Content="Export Elements" 
                        Grid.Row="0" Grid.Column="0"
                        Margin="0,0,4,8"
                        Height="32"/>
                
                <Button Command="{Binding ImportExcelCommand}" 
                        Style="{StaticResource SecondaryButton}" 
                        Content="Import Excel" 
                        Grid.Row="0" Grid.Column="1"
                        Margin="4,0,0,8"
                        Height="32"/>

                <Button Command="{Binding ValidateCommand}" 
                        Style="{StaticResource SecondaryButton}" 
                        Content="Validate Mapping" 
                        Grid.Row="1" Grid.Column="0"
                        Margin="0,0,4,8"
                        Height="32"/>
                
                <Button Command="{Binding ExportReportCommand}" 
                        Style="{StaticResource SecondaryButton}" 
                        Content="Audit Report" 
                        Grid.Row="1" Grid.Column="1"
                        Margin="4,0,0,8"
                        Height="32"/>
                
                <Button Command="{Binding GenerateCommand}" 
                        Style="{StaticResource PremiumButton}" 
                        Content="Generate 5D BOQ Codes" 
                        Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                        Height="35"/>
            </Grid>
        </Border>

        <!-- Progress & Status Panel -->
        <Border Grid.Row="4" Background="#1E293B" CornerRadius="8" Padding="12" BorderBrush="#334155" BorderThickness="1">
            <StackPanel>
                <Grid Margin="0,0,0,6">
                    <TextBlock Text="{Binding StatusText}" Foreground="#94A3B8" FontSize="11" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="Matched: " Foreground="#94A3B8" FontSize="11"/>
                        <TextBlock Text="{Binding MatchedTypesCount}" Foreground="#10B981" FontSize="11" FontWeight="Bold"/>
                    </StackPanel>
                </Grid>
                <ProgressBar Height="6" Value="{Binding ProgressValue}" Background="#0F172A" Foreground="#3B82F6" BorderThickness="0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
